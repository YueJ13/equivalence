Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"clusterByIntersection", "[", "gbSets_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"n", ",", "parent", ",", "rank", ",", 
       RowBox[{"representatives", "=", 
        RowBox[{"{", "}"}]}]}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"n", "=", 
       RowBox[{"Length", "[", "gbSets", "]"}]}], ";", "\n", 
      RowBox[{"parent", "=", 
       RowBox[{"Range", "[", "n", "]"}]}], ";", " ", "\n", 
      RowBox[{"rank", "=", 
       RowBox[{"Table", "[", 
        RowBox[{"0", ",", 
         RowBox[{"{", "n", "}"}]}], "]"}]}], ";", 
      RowBox[{
       RowBox[{"find", "[", "x_", "]"}], ":=", 
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"root", "=", "x"}], "}"}], ",", 
         RowBox[{
          RowBox[{"While", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"parent", "[", 
              RowBox[{"[", "root", "]"}], "]"}], "!=", "root"}], ",", 
            RowBox[{
             RowBox[{
              RowBox[{"parent", "[", 
               RowBox[{"[", "root", "]"}], "]"}], "=", 
              RowBox[{"parent", "[", 
               RowBox[{"[", 
                RowBox[{"parent", "[", 
                 RowBox[{"[", "root", "]"}], "]"}], "]"}], "]"}]}], ";", 
             RowBox[{"root", "=", 
              RowBox[{"parent", "[", 
               RowBox[{"[", "root", "]"}], "]"}]}], ";"}]}], "]"}], ";", 
          "\[IndentingNewLine]", "root"}]}], "]"}]}], ";", 
      RowBox[{
       RowBox[{"union", "[", 
        RowBox[{"x_", ",", "y_"}], "]"}], ":=", 
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"rootX", "=", 
            RowBox[{"find", "[", "x", "]"}]}], ",", 
           RowBox[{"rootY", "=", 
            RowBox[{"find", "[", "y", "]"}]}]}], "}"}], ",", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"rootX", "!=", "rootY"}], ",", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"rank", "[", 
               RowBox[{"[", "rootX", "]"}], "]"}], "<", 
              RowBox[{"rank", "[", 
               RowBox[{"[", "rootY", "]"}], "]"}]}], ",", 
             RowBox[{
              RowBox[{"parent", "[", 
               RowBox[{"[", "rootX", "]"}], "]"}], "=", "rootY"}], ",", 
             RowBox[{
              RowBox[{
               RowBox[{"parent", "[", 
                RowBox[{"[", "rootY", "]"}], "]"}], "=", "rootX"}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"rank", "[", 
                  RowBox[{"[", "rootX", "]"}], "]"}], "==", 
                 RowBox[{"rank", "[", 
                  RowBox[{"[", "rootY", "]"}], "]"}]}], ",", 
                RowBox[{
                 RowBox[{"rank", "[", 
                  RowBox[{"[", "rootX", "]"}], "]"}], "++"}]}], "]"}]}]}], 
            "]"}]}], "]"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Do", "[", 
       RowBox[{
        RowBox[{"Do", "[", 
         RowBox[{
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Intersection", "[", 
              RowBox[{
               RowBox[{"gbSets", "[", 
                RowBox[{"[", 
                 RowBox[{"i", ",", "2"}], "]"}], "]"}], ",", 
               RowBox[{"gbSets", "[", 
                RowBox[{"[", 
                 RowBox[{"j", ",", "2"}], "]"}], "]"}]}], "]"}], "=!=", 
             RowBox[{"{", "}"}]}], ",", 
            RowBox[{
             RowBox[{"union", "[", 
              RowBox[{"i", ",", "j"}], "]"}], ";", "\[IndentingNewLine]", 
             RowBox[{"Break", "[", "]"}], ";"}]}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"j", ",", "1", ",", 
            RowBox[{"i", "-", "1"}]}], "}"}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "2", ",", "n"}], "}"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"representatives", "=", 
       RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"Do", "[", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"find", "[", "i", "]"}], "==", "i"}], ",", 
          RowBox[{"AppendTo", "[", 
           RowBox[{"representatives", ",", 
            RowBox[{"gbSets", "[", 
             RowBox[{"[", 
              RowBox[{"i", ",", "1"}], "]"}], "]"}]}], "]"}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", "n"}], "}"}]}], "]"}], ";", 
      "\[IndentingNewLine]", "representatives"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.977112360142085*^9, 3.977112379420953*^9}, {
   3.9771138186886177`*^9, 3.977113821486909*^9}, {3.977113885262595*^9, 
   3.977113892018762*^9}, 3.977114089143651*^9, {3.9771146584224052`*^9, 
